  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "gh-pages": "^6.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.7"
  }
}
